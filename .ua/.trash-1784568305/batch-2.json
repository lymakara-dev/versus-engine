      "id": "file:apps/workers/src/cli/analytics-sync.ts",
      "type": "file",
      "name": "analytics-sync.ts",
      "filePath": "apps/workers/src/cli/analytics-sync.ts",
      "summary": "`pnpm analytics:sync` CLI that pulls per-video stats and audience retention from the YouTube Analytics API v2 for every published Upload, persists them to VideoAnalytics/RoundRetention, and correlates the retention curve back to individual rounds using the exact scene timing the studio rendered with. Idempotent — each run fully replaces that upload's stored analytics.",
      "tags": ["entry-point", "cli", "analytics", "youtube-api", "batch-job"],
      "complexity": "complex",
      "languageNotes": "Uses Promise.all to fetch headline stats, impression stats, and the retention curve concurrently per upload, then a Prisma $transaction to atomically replace prior RoundRetention rows."
    },
