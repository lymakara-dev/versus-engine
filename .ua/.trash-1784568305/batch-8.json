      "filePath": "apps/dashboard/app/comparisons/[id]/actions.ts",
      "summary": "Next.js Server Actions for the comparison detail page: idempotently queues a Remotion render job for a comparison's frozen videoJson, and lets a human pick the winning A/B thumbnail variant.",
      "tags": ["server-action", "render-queue", "idempotent", "bullmq"],
      "complexity": "moderate",
      "languageNotes": "Uses a composite dedupe key (comparisonId + composition + templateVer + non-terminal status) before enqueueing, matching CLAUDE.md's 'idempotent jobs' rule for BullMQ workers."
    },
