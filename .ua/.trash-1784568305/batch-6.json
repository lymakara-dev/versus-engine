  "nodes": [
    {
      "id": "file:apps/workers/src/cli/batch.ts",
      "type": "file",
      "name": "batch.ts",
      "filePath": "apps/workers/src/cli/batch.ts",
      "summary": "CLI entry point for `pnpm batch --category <slug> --pairs top-<N>` — resolves top-priced VERIFIED products in a category, pairs them into comparisons, builds/saves each comparison, queues a BullMQ render job, and optionally stages staggered publish scheduling and narration synthesis.",
      "tags": ["entry-point", "cli", "batch-processing", "scheduling", "queue-producer"],
      "complexity": "moderate",
      "languageNotes": "Uses node:util parseArgs for flag parsing and a main().catch().finally() chain to set process.exitCode and disconnect Prisma cleanly on both success and failure."
    },
    {
      "id": "function:apps/workers/src/cli/batch.ts:main",
      "type": "function",
      "name": "main",
      "filePath": "apps/workers/src/cli/batch.ts",
      "lineRange": [39, 133],
      "summary": "Parses CLI args, validates the category and pairs/schedule specs, fetches the top-priced VERIFIED products for the category, pairs them, then for each pair builds and saves a comparison, creates a RenderJob, enqueues it on the render queue, and optionally creates a scheduled Upload record.",
      "tags": ["cli", "orchestration", "batch-processing", "entry-point"],
      "complexity": "complex"
    },
    {
      "id": "file:apps/workers/src/cli/pair-products.ts",
      "type": "file",
      "name": "pair-products.ts",
      "filePath": "apps/workers/src/cli/pair-products.ts",
      "summary": "Utility that takes the top N ranked products and pairs them consecutively into head-to-head matchups for batch comparison generation, dropping any trailing unpaired item.",
      "tags": ["utility", "pairing", "batch-processing", "algorithm"],
      "complexity": "simple"
    },
    {
      "id": "function:apps/workers/src/cli/pair-products.ts:pairTopRanked",
      "type": "function",
      "name": "pairTopRanked",
      "filePath": "apps/workers/src/cli/pair-products.ts",
      "lineRange": [6, 13],
      "summary": "Slices the top `count` entries from a ranked list and groups them into consecutive [A, B] pairs, dropping an odd leftover item so every video gets exactly two contenders.",
      "tags": ["utility", "pairing", "generic-function"],
      "complexity": "simple"
    },
