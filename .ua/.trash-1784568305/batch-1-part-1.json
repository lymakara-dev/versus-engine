      "id": "file:apps/studio/src/audio/AudioTrack.tsx",
      "type": "file",
      "name": "AudioTrack.tsx",
      "filePath": "apps/studio/src/audio/AudioTrack.tsx",
      "summary": "Remotion component that renders the composition's looping background music and time-positioned SFX cues, driving the music volume with the per-frame ducking curve from createMusicVolumeFn.",
      "tags": ["audio", "component", "remotion", "sfx"],
      "complexity": "simple"
    },
    {
      "id": "file:apps/studio/src/audio/music.ts",
      "type": "file",
      "name": "music.ts",
      "filePath": "apps/studio/src/audio/music.ts",
      "summary": "Pure audio-math utilities that build the per-frame music volume envelope: base level, dB-to-linear conversion, -6dB ducking around SFX/narration cues, and a 2-second fade-out.",
      "tags": ["audio", "utility", "volume-envelope", "math"],
      "complexity": "moderate",
      "languageNotes": "Returns a closure (frame: number) => number rather than a value, so the ducking curve can be evaluated lazily per rendered frame."
    },
    {
      "id": "file:apps/studio/src/audio/types.ts",
      "type": "file",
      "name": "types.ts",
      "filePath": "apps/studio/src/audio/types.ts",
      "summary": "Shared audio types for the studio renderer: the SfxCue interface and the sfxSrc helper that resolves a cue name to its static asset path.",
      "tags": ["type-definition", "audio", "utility"],
      "complexity": "simple"
    },
    {
      "id": "file:apps/studio/src/components/Background.tsx",
      "type": "file",
      "name": "Background.tsx",
      "filePath": "apps/studio/src/components/Background.tsx",
      "summary": "Renders the animated scene backdrop: a theme-colored gradient plus one of three motif overlays (speed lines, circuit pattern, or drifting grid) selected by theme.motif.",
      "tags": ["component", "background", "animation", "theme"],
      "complexity": "moderate"
    },
    {
      "id": "file:apps/studio/src/components/Confetti.tsx",
      "type": "file",
      "name": "Confetti.tsx",
      "filePath": "apps/studio/src/components/Confetti.tsx",
      "summary": "Physics-based confetti particle burst used in the winner-reveal celebration, computing per-particle trajectories with gravity and randomized seeds via Remotion's deterministic random().",
      "tags": ["component", "animation", "particle-effect", "celebration"],
      "complexity": "moderate",
      "languageNotes": "Uses Remotion's seeded random() (not Math.random()) so particle trajectories render identically on every frame pass, which is required for deterministic video rendering."
    },
    {
      "id": "file:apps/studio/src/compositions/Comparison16x9.tsx",
      "type": "file",
      "name": "Comparison16x9.tsx",
      "filePath": "apps/studio/src/compositions/Comparison16x9.tsx",
      "summary": "The root 16:9 Remotion composition: validates VideoInput, resolves theme/layout/durations, sequences all six scenes with TransitionSeries (fade/slide), overlays the persistent Scoreboard, and mounts AudioTrack. This is the entry point Phase 1 renders end-to-end per CLAUDE.md.",
      "tags": ["entry-point", "composition", "remotion", "orchestration"],
      "complexity": "complex",
      "languageNotes": "Scene modules are imported with `import * as` and stored in a SEQUENTIAL_SCENES array so getDuration/getSfxCues/the component itself can be invoked generically across scenes without a switch statement."
    },
    {
