      "id": "file:packages/comparison/src/build-comparison.ts",
      "type": "file",
      "name": "build-comparison.ts",
      "filePath": "packages/comparison/src/build-comparison.ts",
      "summary": "Prisma-backed orchestrator that loads VERIFIED products and their SpecValues, runs round selection and scoring, generates (or falls back to deterministic) metadata, and freezes the result into the Zod-validated VideoInput contract; also idempotently upserts the built comparison keyed by slug.",
      "tags": ["orchestration", "database-access", "idempotent-write", "video-generation", "service"],
      "complexity": "complex",
      "languageNotes": "Uses inversion of control for narration synthesis (an injected async function) so this package never depends directly on @versus-engine/narration or a TTS provider."
    },
    {
      "id": "file:packages/comparison/src/metadata.test.ts",
      "type": "file",
