      "name": "round-selection.ts",
      "filePath": "packages/comparison/src/round-selection.ts",
      "summary": "Implements the CLAUDE.md round-selection heuristic: scores each SpecDefinition candidate by priorityWeight x normalizedDifference (with an optional retention boost), picks the top 6-8, always includes price, caps badge rounds at one, and guarantees each contender wins at least one round when the data allows.",
      "tags": ["heuristic", "scoring", "algorithm", "business-logic", "round-selection"],
      "complexity": "complex",
      "languageNotes": "Uses type-narrowing predicates (numbers.every((n): n is number => ...)) to safely coerce optional numeric/boolean spec values before ranking."
    },
