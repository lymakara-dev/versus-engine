      "tags": ["test", "unit-test", "metadata", "mocking"],
      "complexity": "simple"
    },
    {
      "id": "file:packages/comparison/src/metadata.ts",
      "type": "file",
      "name": "metadata.ts",
      "filePath": "packages/comparison/src/metadata.ts",
      "summary": "Generates AI-written YouTube title/description/tags/tagline for a comparison via an injectable Anthropic-like client, with prompt building, response parsing, and a deterministic fallback used when no client is configured.",
      "tags": ["ai-generation", "prompt-engineering", "fallback-logic", "metadata", "validation"],
      "complexity": "moderate",
      "languageNotes": "Mirrors the AnthropicLike-interface pattern from packages/ingestion/src/normalize/ai-normalizer.ts so it stays testable without a live API key."
