{
  "nodes": [
    {
      "id": "file:apps/studio/src/Root.tsx",
      "type": "file",
      "name": "Root.tsx",
      "filePath": "apps/studio/src/Root.tsx",
      "summary": "Remotion root component that registers all renderable outputs — the 16:9 and 9:16 comparison video compositions and the two branded thumbnail stills — wiring each to the shared Zod video schema and dynamic duration/resolution calculation.",
      "tags": ["entry-point", "remotion", "composition-registry", "video"],
      "complexity": "moderate"
    },
    {
      "id": "file:apps/studio/src/components/Crown.tsx",
      "type": "file",
      "name": "Crown.tsx",
      "filePath": "apps/studio/src/components/Crown.tsx",
      "summary": "Animated crown component that drops in with a spring, rotates into place, and gains a colored glow — used to visually mark the winning contender.",
      "tags": ["component", "animation", "ui", "winner-reveal"],
      "complexity": "simple",
      "languageNotes": "Combines spring() for the drop-in motion with two interpolate() calls (rotation, glow) driven off a delay-adjusted local frame, matching the project's convention of spring for entrances and interpolate for value animation."
    },
    {
      "id": "file:apps/studio/src/components/Icon.tsx",
      "type": "file",
      "name": "Icon.tsx",
      "filePath": "apps/studio/src/components/Icon.tsx",
      "summary": "Thin wrapper around lucide-react that resolves a kebab-case icon name (e.g. \"dollar-sign\") to the matching PascalCase Lucide icon component, falling back to HelpCircle when no match exists.",
      "tags": ["component", "utility", "icon", "ui"],
      "complexity": "simple"
    },
    {
      "id": "file:apps/studio/src/components/PricePill.tsx",
      "type": "file",
      "name": "PricePill.tsx",
      "filePath": "apps/studio/src/components/PricePill.tsx",
      "summary": "Presentational pill-shaped badge that displays a contender's price with a dollar icon, themed via the shared Theme object and accented with the contender's color.",
      "tags": ["component", "ui", "pricing", "theme"],
      "complexity": "simple"
    },
    {
      "id": "file:apps/studio/src/compositions/ComparisonShort9x16.tsx",
      "type": "file",
      "name": "ComparisonShort9x16.tsx",
      "filePath": "apps/studio/src/compositions/ComparisonShort9x16.tsx",
      "summary": "Barrel re-export that aliases Comparison16x9 as ComparisonShort9x16, reusing the exact same scene component for the 9:16 Shorts variant since layout adapts internally from the `meta.aspect` prop.",
      "tags": ["barrel", "composition", "shorts", "re-export"],
      "complexity": "simple",
      "languageNotes": "Zero-logic re-export — the only difference between the 16:9 and 9:16 outputs lives in the <Composition> registration (id, resolution, example props) in Root.tsx, not in the component itself."
    },
    {
      "id": "file:apps/studio/src/compositions/Thumbnail16x9.tsx",
      "type": "file",
      "name": "Thumbnail16x9.tsx",
      "filePath": "apps/studio/src/compositions/Thumbnail16x9.tsx",
      "summary": "Branded 16:9 still-image thumbnail template (per PROJECT_PLAN.md) rendering both contenders side-by-side with a crown on the winner, price pills, and the video title, generated from the same VideoInput data as the video itself.",
      "tags": ["component", "thumbnail", "still-composition", "marketing"],
      "complexity": "moderate"
    },
    {
      "id": "file:apps/studio/src/compositions/Thumbnail16x9B.tsx",
      "type": "file",
      "name": "Thumbnail16x9B.tsx",
      "filePath": "apps/studio/src/compositions/Thumbnail16x9B.tsx",
      "summary": "Alternate 16:9 thumbnail template used for A/B testing, using diagonal color-blocked halves per contender instead of the dark panel style of Thumbnail16x9, driven by the identical VideoInput data.",
      "tags": ["component", "thumbnail", "still-composition", "ab-testing"],
      "complexity": "moderate",
      "languageNotes": "Uses CSS clip-path polygons to create the diagonal split, a distinct visual technique from the boxed-panel layout in Thumbnail16x9."
    },
