{
  "name": "versus-engine",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "render": "pnpm --filter studio render",
    "db:seed": "pnpm --filter @versus-engine/db seed",
    "db:migrate": "pnpm --filter @versus-engine/db migrate",
    "db:generate": "pnpm --filter @versus-engine/db generate",
    "ingest": "pnpm --filter workers ingest",
    "batch": "pnpm --filter workers batch",
    "worker": "pnpm --filter workers worker",
    "youtube:auth": "pnpm --filter workers youtube:auth",
    "lambda:deploy-function": "pnpm --filter workers lambda:deploy-function",
    "lambda:deploy-site": "pnpm --filter workers lambda:deploy-site",
    "analytics:sync": "pnpm --filter workers analytics:sync"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "prisma": "6.19.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
