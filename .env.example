# PostgreSQL
DATABASE_URL="postgresql://versus:versus@localhost:5432/versus_engine?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO (S3-compatible, dev asset store)
S3_ENDPOINT="http://localhost:9002"
S3_ACCESS_KEY_ID="versus"
S3_SECRET_ACCESS_KEY="versus-secret"
S3_BUCKET="versus-engine"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# Anthropic (AI-assisted research / normalization)
ANTHROPIC_API_KEY=""

# OpenAI TTS (Phase 5, optional — only needed for `pnpm batch --narration`)
OPENAI_API_KEY=""

# YouTube Data API v3 (Phase 4)
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:8765/oauth2callback"
# Run `pnpm youtube:auth` once (after setting the three vars above) to mint this
# (also covers Phase 5's `pnpm analytics:sync` — re-run youtube:auth if this
# token predates the yt-analytics.readonly scope being added):
YOUTUBE_REFRESH_TOKEN=""

# Remotion Lambda (Phase 5 — set RENDER_TARGET=lambda to use it, otherwise
# renders run locally). Credentials come from an IAM user set up per
# https://www.remotion.dev/docs/lambda/setup — names are REMOTION_AWS_* on
# purpose, distinct from AWS_* so they don't collide with other AWS SDKs.
RENDER_TARGET="local"
REMOTION_AWS_ACCESS_KEY_ID=""
REMOTION_AWS_SECRET_ACCESS_KEY=""
REMOTION_AWS_REGION="us-east-1"
# Run `pnpm lambda:deploy-function` once to mint this:
REMOTION_LAMBDA_FUNCTION_NAME=""
# Run `pnpm lambda:deploy-site` (again after every studio change) to mint this:
REMOTION_LAMBDA_SERVE_URL=""
